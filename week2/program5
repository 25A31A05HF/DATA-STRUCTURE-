#include <iostream>
using namespace std;

class Demo
{
public:
    int add(int a, int b)
    {
        return a + b;
    }

    int add(int a, int b, int c)
    {
        return a + b + c;
    }

    float add(float a, float b)
    {
        return a + b;
    }
};

int main()
{
    Demo obj;

    cout << "Sum of two integers: " << obj.add(5, 10) << endl;
    cout << "Sum of three integers: " << obj.add(5, 10, 15) << endl;
    cout << "Sum of two floats: " << obj.add(2.5f, 3.5f) << endl;

    return 0;
}
