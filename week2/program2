#include <iostream>
using namespace std;

int main()
{
    int n;
    cout << "Enter number of elements: ";
    cin >> n;

    int arr[n];
    int *ptr;

    ptr = arr;   // pointer points to first element of array

    // Reading elements
    cout << "Enter array elements:\n";
    for(int i = 0; i < n; i++)
    {
        cin >> *(ptr + i);
    }

    // Displaying elements
    cout << "Array elements are: ";
    for(int i = 0; i < n; i++)
    {
        cout << *(ptr + i) << " ";
    }

    return 0;
}
