#include <iostream>
using namespace std;

int main()
{
    int n, key, count = 0;

    cout << "Enter number of elements: ";
    cin >> n;

    int arr[n];

    cout << "Enter array elements:\n";
    for(int i = 0; i < n; i++)
    {
        cin >> arr[i];
    }

    cout << "Enter element to search: ";
    cin >> key;

    for(int i = 0; i < n; i++)
    {
        if(arr[i] == key)
        {
            count++;
            cout << "Found at position: " << i + 1 << endl;
        }
    }

    cout << "Total occurrences = " << count;

    return 0;
}
